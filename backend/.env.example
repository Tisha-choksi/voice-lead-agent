# ── Sarvam AI ─────────────────────────────────────────────────
# Get free key at: https://dashboard.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_MODEL=sarvam-m
SARVAM_BASE_URL=https://api.sarvam.ai/v1
SARVAM_MAX_TOKENS=400
SARVAM_TEMPERATURE=0.7

# ── Edge TTS Voice (Microsoft Neural, FREE — no key needed) ───
# Indian English: en-IN-NeerjaNeural | en-IN-PrabhatNeural
# Hindi:          hi-IN-SwaraNeural  | hi-IN-MadhurNeural
# US English:     en-US-JennyNeural
EDGE_TTS_VOICE=en-IN-NeerjaNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_PITCH=+0Hz

# ── Database ──────────────────────────────────────────────────
DB_PATH=leads.db

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Server ───────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# ── Agent ────────────────────────────────────────────────────
AGENT_NAME=Aria
AGENT_COMPANY=our company
