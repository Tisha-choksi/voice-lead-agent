# ─────────────────────────────────────────────────────────────────
# .gitignore — What NOT to push to GitHub
# ─────────────────────────────────────────────────────────────────

# ── SECRET FILES — MOST IMPORTANT ─────────────────────────────
# These contain API keys and passwords. NEVER commit them.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
venv/
env/
.venv/

# SQLite database — generated at runtime, not source code
*.db
*.sqlite
*.sqlite3

# Python test cache
.pytest_cache/
.coverage
htmlcov/

# ── Node / Next.js ────────────────────────────────────────────
node_modules/

# Next.js build output — regenerated by `npm run build`
.next/
out/

# Vercel deployment cache
.vercel

# ── OS & Editor ───────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db

.idea/
.vscode/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*